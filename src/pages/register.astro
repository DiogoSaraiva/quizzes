---
import Layout from "../layouts/Layout.astro";

if (Astro.locals.user) return Astro.redirect("/");

const error = Astro.url.searchParams.get("error");
const success = Astro.url.searchParams.get("success");

const errors: Record<string, string> = {
	exists: "Este username ou email já está registado.",
	invalid: "Preenche todos os campos corretamente.",
	username: "Username inválido. Usa apenas letras, números, hífen ou underscore.",
	password: "A password deve ter pelo menos 8 caracteres.",
};
---

<Layout title="Registar">
	<div class="auth-wrap">
		<h1>Criar conta</h1>
		<p class="subtitle">O acesso é aprovado manualmente.</p>

		{error && <p class="alert alert-error">{errors[error] ?? "Erro inesperado."}</p>}
		{success && (
			<p class="alert alert-success">
				Pedido enviado! Aguarda aprovação antes de poderes entrar.
			</p>
		)}

		{!success && (
			<form method="POST" action="/api/auth/register">
				<label>
					Username
					<input
						type="text"
						name="username"
						id="username-input"
						required
						autocomplete="username"
						pattern="[A-Za-z0-9_-]+"
					/>
					<small class="field-hint" id="username-hint">Letras, números, <code>-</code> e <code>_</code> — sem espaços</small>
				</label>
				<label>
					Email
					<input type="email" name="email" required autocomplete="email" />
				</label>
				<label>
					Password
					<input type="password" name="password" id="password-input" required autocomplete="new-password" minlength="8" />
					<small class="field-hint" id="password-hint">Mínimo 8 caracteres</small>
				</label>
				<label class="label-check">
					<input type="checkbox" name="consent" required />
					<span>
						Li e aceito a <a href="/privacy" target="_blank">Política de Privacidade</a>.
						Consinto no tratamento dos meus dados para os fins descritos.
					</span>
				</label>
				<button type="submit" class="btn-primary" id="submit-btn" disabled>Pedir acesso</button>
			</form>
		)}

		<p class="footer-link">Já tens conta? <a href="/login">Entrar</a></p>
	</div>
</Layout>

<style>
	.auth-wrap {
		max-width: 400px;
		margin: 3rem auto;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	h1 {
		font-size: 1.75rem;
		font-weight: 700;
		letter-spacing: -0.04em;
	}

	.subtitle {
		color: var(--q-text-subtle);
		font-size: 0.9375rem;
		margin-top: -0.75rem;
	}

	.alert {
		padding: 0.75rem 1rem;
		border-radius: 0.5rem;
		font-size: 0.9375rem;
	}

	.alert-error {
		background: var(--q-wrong-bg);
		border: 1px solid var(--q-wrong);
		color: var(--q-wrong-text);
	}

	.alert-success {
		background: var(--q-correct-bg);
		border: 1px solid var(--q-correct);
		color: #86efac;
	}

	form {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	label {
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
		font-size: 0.875rem;
		color: var(--q-text-muted);
	}

	input {
		padding: 0.625rem 0.875rem;
		background: var(--q-surface);
		border: 1.5px solid var(--q-border);
		border-radius: 0.5rem;
		color: var(--q-text);
		font-size: 1rem;
		outline: none;
		transition: border-color 0.15s;
	}

	input:focus {
		border-color: var(--q-accent);
	}

	input.invalid {
		border-color: var(--q-wrong);
	}

	.field-hint {
		font-size: 0.75rem;
		color: var(--q-text-subtle);
	}

	.field-hint code {
		background: var(--q-bg);
		padding: 0.05em 0.3em;
		border-radius: 0.2rem;
	}

	.field-hint.error {
		color: var(--q-wrong-text);
	}

	.btn-primary {
		margin-top: 0.25rem;
		padding: 0.75rem;
		background: var(--q-accent);
		color: white;
		border: none;
		border-radius: 0.5rem;
		font-size: 1rem;
		font-weight: 600;
		cursor: pointer;
		transition: background 0.15s;
	}

	.btn-primary:hover {
		background: var(--q-accent-hover);
	}

	.footer-link {
		text-align: center;
		font-size: 0.875rem;
		color: var(--q-text-subtle);
	}

	.footer-link a {
		color: var(--q-accent-light);
		text-decoration: none;
	}

	.label-check {
		flex-direction: row;
		align-items: flex-start;
		gap: 0.625rem;
		color: var(--q-text-subtle);
		font-size: 0.8125rem;
		cursor: pointer;
	}

	.label-check input {
		margin-top: 0.2rem;
		width: auto;
		flex-shrink: 0;
		accent-color: var(--q-accent);
	}

	.label-check a {
		color: var(--q-accent-light);
		text-decoration: underline;
	}

	.btn-primary:disabled {
		opacity: 0.4;
		cursor: not-allowed;
	}
</style>

<script>
	const form = document.querySelector("form");
	const btn = document.getElementById("submit-btn") as HTMLButtonElement | null;
	const usernameInput = document.getElementById("username-input") as HTMLInputElement | null;
	const usernameHint = document.getElementById("username-hint") as HTMLElement | null;
	const passwordInput = document.getElementById("password-input") as HTMLInputElement | null;
	const passwordHint = document.getElementById("password-hint") as HTMLElement | null;

	function checkUsername() {
		if (!usernameInput || !usernameHint) return;
		const val = usernameInput.value;
		const invalid = val.length > 0 && !/^[A-Za-z0-9_-]+$/.test(val);
		usernameInput.classList.toggle("invalid", invalid);
		usernameHint.classList.toggle("error", invalid);
		usernameHint.textContent = invalid
			? "Caracteres inválidos — remove espaços e símbolos."
			: "Letras, números, - e _ — sem espaços";
	}

	function checkPassword() {
		if (!passwordInput || !passwordHint) return;
		const val = passwordInput.value;
		const invalid = val.length > 0 && val.length < 8;
		passwordInput.classList.toggle("invalid", invalid);
		passwordHint.classList.toggle("error", invalid);
		passwordHint.textContent = invalid
			? "A password deve ter pelo menos 8 caracteres."
			: "Mínimo 8 caracteres";
	}

	if (form && btn) {
		const check = () => {
			checkUsername();
			checkPassword();
			btn.disabled = !form.checkValidity();
		};
		form.addEventListener("input", check);
		check();
	}
</script>
