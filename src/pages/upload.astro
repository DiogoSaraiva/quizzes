---
import Layout from "../layouts/Layout.astro";

const user = Astro.locals.user;

// Apenas editores e admins podem aceder
if (!user || (user.role !== "editor" && user.role !== "admin")) {
	return Astro.redirect("/");
}
---

<Layout title="Carregar Quiz">
	<h1>Carregar Quiz</h1>
	<p class="subtitle">
		Cola o JSON gerado pelo Claude/ChatGPT e clica em <strong>Carregar</strong>.
	</p>

	<div id="status" class="status hidden"></div>

	<form id="upload-form">
		<label class="field-label" for="json-input">JSON do Quiz</label>
		<textarea
			id="json-input"
			name="json"
			rows="20"
			placeholder='{"title": "...", "subject": "...", "slug": "...", "questions": [...]}'
			required
		></textarea>
		<div class="form-footer">
			<button type="submit" class="btn-primary" id="submit-btn">Carregar</button>
			<span class="hint">Ficheiros com o mesmo <code>slug</code> são substituídos automaticamente.</span>
		</div>
	</form>

	<details class="format-help">
		<summary>Prompt para o Claude / ChatGPT</summary>
		<div class="prompt-header">
			<p class="prompt-desc">Copia este prompt e envia juntamente com os slides ou documento da matéria.</p>
			<button class="btn-copy" id="copy-prompt-btn">Copiar prompt</button>
		</div>
		<pre id="prompt-text"><code>{`Analisa o conteúdo fornecido e cria um quiz de estudo.
Responde APENAS com JSON válido, sem texto antes ou depois, sem blocos de código (sem \`\`\`).

Formato obrigatório:
{
  "title": "Título descritivo do quiz",
  "description": "Uma frase sobre o que é abordado",
  "subject": "Nome da cadeira/disciplina",
  "topic": "Nome do tema/capítulo (omitir se for quiz geral da cadeira)",
  "slug": "cadeira-tema-numero",
  "questions": [
    {
      "text": "Texto da pergunta?",
      "type": "multiple_choice",
      "order": 1,
      "explanation": "Explicação breve de porque a resposta correta está certa.",
      "options": [
        { "text": "Opção A", "is_correct": false },
        { "text": "Opção B", "is_correct": true },
        { "text": "Opção C", "is_correct": false },
        { "text": "Opção D", "is_correct": false }
      ]
    }
  ]
}

Regras:
- Cria entre 15 e 25 perguntas
- Cada pergunta multiple_choice tem exatamente 4 opções, apenas 1 correta
- Perguntas de verdadeiro/falso usam type "true_false" com 2 opções: "Verdadeiro" e "Falso"
- O slug usa só minúsculas, sem acentos, palavras separadas por hífens (ex: "anatomia-sistema-nervoso-1")
- Cada pergunta deve ter um campo "explanation" com 1-2 frases a explicar porque a resposta correta está certa
- O campo "explanation" é opcional — omite se não houver explicação útil a acrescentar
- As perguntas devem cobrir os conceitos mais importantes do conteúdo
- Varia o tipo de pergunta: definições, aplicação, comparação, identificação
- Não repitas perguntas semelhantes
- Faz perguntas difíceis, já que esse quiz irá servir como elemento de estudo para aluno de licenciatura`}</code></pre>
	</details>

	<details class="format-help">
		<summary>Formato esperado do JSON</summary>
		<pre><code>{`{
  "title": "Anatomia — Sistema Nervoso",
  "description": "Neurónios e sinapses",
  "subject": "Anatomia",
  "topic": "Sistema Nervoso",
  "topic_order": 0,
  "slug": "anatomia-sistema-nervoso-1",
  "questions": [
    {
      "text": "Qual é a unidade funcional do sistema nervoso?",
      "type": "multiple_choice",
      "order": 1,
      "explanation": "O neurónio é a célula especializada na transmissão de impulsos nervosos.",
      "options": [
        { "text": "Neurónio",  "is_correct": true  },
        { "text": "Axónio",    "is_correct": false },
        { "text": "Dendrito",  "is_correct": false },
        { "text": "Sinapse",   "is_correct": false }
      ]
    },
    {
      "text": "O sistema nervoso central inclui o cérebro e a medula espinhal.",
      "type": "true_false",
      "order": 2,
      "explanation": "O SNC é composto pelo encéfalo (cérebro, cerebelo e tronco encefálico) e pela medula espinhal.",
      "options": [
        { "text": "Verdadeiro", "is_correct": true  },
        { "text": "Falso",      "is_correct": false }
      ]
    }
  ]
}`}</code></pre>
	</details>
</Layout>

<script>
	const form = document.getElementById("upload-form") as HTMLFormElement;
	const statusEl = document.getElementById("status") as HTMLDivElement;
	const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;

	form.addEventListener("submit", async (e) => {
		e.preventDefault();
		const raw = (document.getElementById("json-input") as HTMLTextAreaElement).value.trim();

		statusEl.className = "status hidden";
		submitBtn.disabled = true;
		submitBtn.textContent = "A carregar…";

		let parsed: unknown;
		try {
			parsed = JSON.parse(raw);
		} catch {
			showError("JSON inválido — verifica a sintaxe.");
			return;
		}

		try {
			const res = await fetch("/api/quizzes/upload", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify(parsed),
			});

			const data = await res.json() as { ok?: boolean; error?: string; slug?: string; replaced?: boolean };

			if (res.ok && data.ok) {
				const action = data.replaced ? "substituído" : "criado";
				showSuccess(`Quiz ${action} com sucesso! <a href="/${data.slug}">Abrir quiz →</a>`);
				(document.getElementById("json-input") as HTMLTextAreaElement).value = "";
			} else {
				showError(data.error ?? "Erro desconhecido");
			}
		} catch {
			showError("Erro de rede. Tenta novamente.");
		} finally {
			submitBtn.disabled = false;
			submitBtn.textContent = "Carregar";
		}
	});

	function showError(msg: string) {
		statusEl.innerHTML = msg;
		statusEl.className = "status error";
	}

	function showSuccess(msg: string) {
		statusEl.innerHTML = msg;
		statusEl.className = "status success";
	}

	const copyBtn = document.getElementById("copy-prompt-btn") as HTMLButtonElement;
	copyBtn?.addEventListener("click", () => {
		const promptEl = document.getElementById("prompt-text");
		const text = promptEl?.textContent?.trim() ?? "";
		navigator.clipboard.writeText(text).then(() => {
			copyBtn.textContent = "Copiado!";
			setTimeout(() => { copyBtn.textContent = "Copiar prompt"; }, 2000);
		});
	});
</script>

<style>
	h1 {
		font-size: 2rem;
		font-weight: 700;
		margin-bottom: 0.5rem;
		letter-spacing: -0.05em;
	}

	.subtitle {
		color: var(--q-text-muted);
		margin-bottom: 1.5rem;
	}

	.status {
		padding: 0.75rem 1rem;
		border-radius: 0.5rem;
		margin-bottom: 1rem;
		font-size: 0.9375rem;
	}

	.status.error {
		background: var(--q-wrong-bg);
		color: var(--q-wrong-text);
		border: 1px solid var(--q-wrong);
	}

	.status.success {
		background: var(--q-correct-bg);
		color: var(--q-correct-text);
		border: 1px solid var(--q-correct);
	}

	.status.success a {
		color: var(--q-correct-text);
		font-weight: 600;
	}

	.field-label {
		display: block;
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--q-text-muted);
		margin-bottom: 0.5rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	textarea {
		width: 100%;
		background: var(--q-surface);
		color: var(--q-text);
		border: 1px solid var(--q-border);
		border-radius: 0.5rem;
		padding: 0.875rem;
		font-family: monospace;
		font-size: 0.85rem;
		resize: vertical;
		outline: none;
		transition: border-color 0.15s;
	}

	textarea:focus {
		border-color: var(--q-accent);
	}

	.form-footer {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-top: 1rem;
		flex-wrap: wrap;
	}

	.hint {
		font-size: 0.8125rem;
		color: var(--q-text-subtle);
	}

	.hint code {
		background: var(--q-surface);
		padding: 0.1em 0.35em;
		border-radius: 0.25rem;
		font-size: 0.875em;
	}

	.format-help {
		margin-top: 2rem;
		border: 1px solid var(--q-border);
		border-radius: 0.5rem;
		overflow: hidden;
	}

	.format-help summary {
		padding: 0.875rem 1rem;
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--q-text-muted);
		cursor: pointer;
		user-select: none;
		list-style: none;
	}

	.format-help summary::-webkit-details-marker {
		display: none;
	}

	.format-help summary::before {
		content: "▶ ";
		font-size: 0.6rem;
		color: var(--q-accent-light);
	}

	details[open] .format-help summary::before {
		content: "▼ ";
	}

	.format-help pre {
		margin: 0;
		padding: 1rem;
		background: var(--q-surface);
		border-top: 1px solid var(--q-border);
		overflow-x: auto;
	}

	.format-help code {
		font-size: 0.8125rem;
		color: var(--q-text-muted);
		font-family: monospace;
	}

	.prompt-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.75rem 1rem;
		border-top: 1px solid var(--q-border);
		background: var(--q-surface);
		flex-wrap: wrap;
	}

	.prompt-desc {
		margin: 0;
		font-size: 0.8125rem;
		color: var(--q-text-muted);
	}

	.btn-copy {
		padding: 0.35rem 0.85rem;
		border-radius: 0.375rem;
		border: 1px solid var(--q-border);
		background: var(--q-bg);
		color: var(--q-text-muted);
		font-size: 0.8125rem;
		font-weight: 600;
		cursor: pointer;
		transition: border-color 0.15s, color 0.15s;
		white-space: nowrap;
	}

	.btn-copy:hover {
		border-color: var(--q-accent);
		color: var(--q-accent);
	}
</style>
