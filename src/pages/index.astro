---
import Layout from "../layouts/Layout.astro";
import { env } from "cloudflare:workers";
import type { Quiz } from "../lib/db";

type QuizWithUploader = Quiz & { uploader_username: string | null };

let quizzes: QuizWithUploader[] = [];
try {
	const { results } = await env.DB.prepare(
		`SELECT q.id, q.slug, q.title, q.description, q.subject, q.topic, q.topic_order, u.username AS uploader_username
		 FROM quizzes q
		 LEFT JOIN users u ON q.uploaded_by = u.id
		 ORDER BY q.subject ASC, q.topic_order ASC, q.topic ASC NULLS LAST, q.title ASC`
	).all<QuizWithUploader>();
	quizzes = results;
} catch (err) {
	console.error("Failed to load quizzes:", err);
}

// Agrupar por cadeira → temas
interface TopicGroup {
	general: QuizWithUploader | null; // quiz sem tema (geral da cadeira)
	byTopic: Map<string, QuizWithUploader[]>;
}

const bySubject = new Map<string, TopicGroup>();

for (const quiz of quizzes) {
	const subject = quiz.subject ?? "Sem Cadeira";
	if (!bySubject.has(subject)) {
		bySubject.set(subject, { general: null, byTopic: new Map() });
	}
	const group = bySubject.get(subject)!;

	if (!quiz.topic) {
		// sem tema = quiz geral da cadeira
		group.general = quiz;
	} else {
		if (!group.byTopic.has(quiz.topic)) {
			group.byTopic.set(quiz.topic, []);
		}
		group.byTopic.get(quiz.topic)!.push(quiz);
	}
}
---

<Layout title="Quizzes">
	<h1>Quizzes</h1>

	{
		bySubject.size === 0 ? (
			<p class="empty">Nenhum quiz disponível ainda.</p>
		) : (
			<div class="subjects">
				{[...bySubject.entries()].map(([subject, group]) => (
					<details class="subject-card" open>
						<summary class="subject-name">{subject}</summary>

						<div class="subject-body">
							{/* Exame Geral — agrega todos os temas */}
							<a
								href={`/exam/${encodeURIComponent(subject)}`}
								class="quiz-link exam"
							>
								<span class="tag-exam">Quiz Geral</span>
								<span>Todos os temas</span>
							</a>

							{/* Quizzes por tema */}
							{[...group.byTopic.entries()].map(([topic, topicQuizzes]) => (
								<div class="topic-group">
									<span class="topic-label">{topic}</span>
									<div class="topic-quizzes">
										{topicQuizzes.map((q) => (
											<a href={`/${q.slug}`} class="quiz-link">
												<span class="quiz-title">{q.title}</span>
												{q.uploader_username && (
													<span class="quiz-uploader">por {q.uploader_username}</span>
												)}
											</a>
										))}
									</div>
								</div>
							))}
						</div>
					</details>
				))}
			</div>
		)
	}
</Layout>

<style>
	h1 {
		font-size: 2rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
		letter-spacing: -0.05em;
	}

	.subjects {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.subject-card {
		background: var(--q-surface);
		border: 1px solid var(--q-border);
		border-radius: 0.75rem;
		overflow: hidden;
	}

	.subject-name {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 1rem 1.25rem;
		font-size: 1.1rem;
		font-weight: 600;
		cursor: pointer;
		list-style: none;
		user-select: none;
	}

	.subject-name::before {
		content: "▶";
		font-size: 0.65rem;
		color: var(--q-accent-light);
		transition: transform 0.2s;
		flex-shrink: 0;
	}

	details[open] .subject-name::before {
		transform: rotate(90deg);
	}

	.subject-name::-webkit-details-marker {
		display: none;
	}

	.subject-body {
		padding: 0 1.25rem 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.quiz-link {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.625rem 0.875rem;
		background: var(--q-bg);
		border: 1px solid var(--q-surface);
		border-radius: 0.5rem;
		text-decoration: none;
		color: var(--q-text);
		font-size: 0.9375rem;
		transition:
			border-color 0.15s,
			background 0.15s;
	}

	.quiz-link:hover {
		border-color: var(--q-accent);
		background: var(--q-accent-bg);
		color: #fff;
	}

	.quiz-link.exam {
		border-color: var(--q-accent);
		background: var(--q-accent-bg);
	}

	.quiz-link.exam:hover {
		border-color: var(--q-accent-light);
		background: var(--q-accent-hover);
	}

	.tag-exam {
		display: inline-block;
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: #fff;
		background: var(--q-accent);
		border-radius: 0.25rem;
		padding: 0.1rem 0.4rem;
		flex-shrink: 0;
	}

	.topic-group {
		border-left: 2px solid var(--q-border);
		padding-left: 0.75rem;
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
	}

	.topic-label {
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--q-text-subtle);
		padding: 0.25rem 0;
	}

	.topic-quizzes {
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
	}

	.quiz-title {
		flex: 1;
	}

	.quiz-uploader {
		font-size: 0.75rem;
		color: var(--q-text-subtle);
		white-space: nowrap;
	}

	.quiz-link:hover .quiz-uploader {
		color: var(--q-accent-text);
	}

	.empty {
		color: var(--q-text-subtle);
		text-align: center;
		padding: 3rem;
	}
</style>
