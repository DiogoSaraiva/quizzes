---
import Layout from "../../layouts/Layout.astro";
import { env } from "cloudflare:workers";
import type { Option, Question } from "../../lib/db";

const subject = decodeURIComponent(Astro.params.subject ?? "");
if (!subject) return Astro.redirect("/");

// Buscar todas as perguntas ordenadas por tema → ordem dentro do quiz
const { results: questions } = await env.DB.prepare(
	`SELECT q.id, q.text, q.explanation, q.type, q."order"
	 FROM questions q
	 JOIN quizzes qz ON q.quiz_id = qz.id
	 WHERE qz.subject = ?
	 ORDER BY qz.topic_order ASC, qz.topic ASC NULLS LAST, q."order" ASC, q.id ASC`
)
	.bind(subject)
	.all<Question & { options?: Option[] }>();

if (questions.length === 0) return Astro.redirect("/");

for (const q of questions) {
	const { results: options } = await env.DB.prepare(
		'SELECT * FROM options WHERE question_id = ? ORDER BY "order" ASC, id ASC'
	)
		.bind(q.id)
		.all<Option>();
	q.options = options;
}

const examJson = JSON.stringify({ subject, questions });
---

<Layout title={`${subject} — Quiz Geral`}>
	<div class="quiz-header">
		<span class="subject">{subject}</span>
		<h1>Quiz Geral</h1>
		<p class="description">
			Todas as perguntas de todos os temas, por ordem.
		</p>
	</div>

	<div id="quiz-root" data-quiz={examJson}>
		<div id="screen-start">
			<p class="meta">{questions.length} perguntas</p>
			<div id="saved-notice" class="hidden saved-notice">
				<p id="saved-text" class="saved-text"></p>
				<div class="start-btns">
					<button id="btn-continue" class="btn-primary">Continuar</button>
					<button id="btn-restart" class="btn-secondary">Recomeçar</button>
				</div>
			</div>
			<button id="btn-start" class="btn-primary">Iniciar Quiz Geral</button>
		</div>

		<div id="screen-player" class="hidden">
			<div class="progress-bar">
				<div id="progress-fill"></div>
			</div>
			<p class="counter">
				Pergunta <span id="q-current">1</span> de <span id="q-total"
					>{questions.length}</span
				>
			</p>
			<div id="q-text" class="question-text"></div>
			<div id="q-options" class="options-list"></div>
			<div id="q-explanation" class="explanation hidden"></div>
			<button id="btn-next" class="btn-primary hidden">Próxima</button>
		</div>

		<div id="screen-results" class="hidden">
			<div class="results-inner">
				<div id="score-circle" class="score-circle">
					<span id="score-label"></span>
				</div>
				<h2 id="result-title"></h2>
				<p id="result-detail" class="result-detail"></p>
				<div class="result-actions">
					<button id="btn-retry" class="btn-secondary">Repetir Exame</button>
					<a href="/" class="btn-outline">Voltar</a>
				</div>
			</div>
		</div>
	</div>
</Layout>

<script>
	interface Option {
		id: number;
		text: string;
		is_correct: number;
	}
	interface Question {
		id: number;
		text: string;
		explanation: string | null;
		options: Option[];
	}
	interface ExamData {
		subject: string;
		questions: Question[];
	}

	const root = document.getElementById("quiz-root")!;
	const exam: ExamData = JSON.parse(root.dataset.quiz!);
	const questions = exam.questions;

	let current = 0;
	let correct = 0;
	let answered = false;

	const $ = (id: string) => document.getElementById(id)!;
	const show = (el: HTMLElement) => el.classList.remove("hidden");
	const hide = (el: HTMLElement) => el.classList.add("hidden");

	const subject = exam.subject;

	async function saveProgress() {
		await fetch("/api/progress", {
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify({ subject, current, correct }),
		}).catch(() => {});
	}

	async function clearProgress() {
		await fetch("/api/progress", {
			method: "DELETE",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify({ subject }),
		}).catch(() => {});
	}

	// Verificar progresso guardado
	const res = await fetch(`/api/progress?subject=${encodeURIComponent(subject)}`).catch(() => null);
	const saved: { current: number; correct: number } | null = res?.ok ? await res.json() : null;

	if (saved && saved.current > 0) {
		$("saved-text").textContent =
			`Progresso guardado — pergunta ${saved.current + 1} de ${questions.length}`;
		show($("saved-notice"));
		hide($("btn-start"));

		$("btn-continue").addEventListener("click", () => {
			current = saved.current;
			correct = saved.correct;
			hide($("screen-start"));
			show($("screen-player"));
			renderQuestion();
		});

		$("btn-restart").addEventListener("click", async () => {
			await clearProgress();
			hide($("screen-start"));
			show($("screen-player"));
			renderQuestion();
		});
	}

	function renderQuestion() {
		answered = false;
		const q = questions[current];
		$("q-current").textContent = String(current + 1);
		$("q-text").textContent = q.text;
		$("q-options").innerHTML = "";
		const expEl = $("q-explanation");
		expEl.textContent = "";
		hide(expEl);
		hide($("btn-next"));
		$("btn-next").textContent =
			current === questions.length - 1 ? "Ver Resultado" : "Próxima";

		($("progress-fill") as HTMLElement).style.width =
			`${(current / questions.length) * 100}%`;

		const letters = ["A", "B", "C", "D", "E", "F"];
		q.options.forEach((opt, i) => {
			const btn = document.createElement("button");
			btn.className = "option-btn";

			const letter = document.createElement("span");
			letter.className = "option-letter";
			letter.textContent = letters[i];

			const text = document.createElement("span");
			text.className = "option-text";
			text.textContent = opt.text;

			btn.appendChild(letter);
			btn.appendChild(text);
			btn.addEventListener("click", () => selectOption(i));
			$("q-options").appendChild(btn);
		});
	}

	function selectOption(chosenIndex: number) {
		if (answered) return;
		answered = true;

		const q = questions[current];
		if (q.options[chosenIndex].is_correct) correct++;

		$("q-options").querySelectorAll(".option-btn").forEach((btn, i) => {
			(btn as HTMLButtonElement).disabled = true;
			if (q.options[i].is_correct) btn.classList.add("correct");
			else if (i === chosenIndex) btn.classList.add("wrong");
		});

		if (q.explanation) {
			const expEl = $("q-explanation");
			expEl.textContent = q.explanation;
			show(expEl);
		}

		show($("btn-next"));
	}

	function showResults() {
		hide($("screen-player"));
		show($("screen-results"));
		($("progress-fill") as HTMLElement).style.width = "100%";

		const total = questions.length;
		const pct = Math.round((correct / total) * 100);
		$("score-label").textContent = `${correct}/${total}`;
		$("result-detail").textContent = `${pct}% de respostas corretas`;

		const circle = $("score-circle");
		if (pct >= 80) {
			circle.classList.add("excellent");
			$("result-title").textContent = "Aprovado!";
		} else if (pct >= 60) {
			circle.classList.add("good");
			$("result-title").textContent = "Quase lá!";
		} else {
			circle.classList.add("poor");
			$("result-title").textContent = "Continua a estudar!";
		}
	}

	$("btn-start").addEventListener("click", () => {
		hide($("screen-start"));
		show($("screen-player"));
		renderQuestion();
	});

	$("btn-next").addEventListener("click", async () => {
		if (current < questions.length - 1) {
			current++;
			await saveProgress();
			renderQuestion();
		} else {
			await clearProgress();
			showResults();
		}
	});

	document.addEventListener("keydown", (e) => {
		if ($("screen-player").classList.contains("hidden")) return;

		const letters = ["a", "b", "c", "d", "e", "f"];
		const idx = letters.indexOf(e.key.toLowerCase());

		if (idx !== -1 && !answered) {
			const btns = $("q-options").querySelectorAll(".option-btn");
			if (idx < btns.length) selectOption(idx);
			return;
		}

		if ((e.key === "Enter" || e.key === " ") && answered) {
			e.preventDefault();
			($("btn-next") as HTMLButtonElement).click();
		}
	});

	$("btn-retry").addEventListener("click", () => {
		current = 0;
		correct = 0;
		$("score-circle").className = "score-circle";
		hide($("screen-results"));
		show($("screen-player"));
		renderQuestion();
	});
</script>

<style is:global>
	.quiz-header {
		margin-bottom: 2rem;
	}

	.subject {
		display: inline-block;
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--q-accent-light);
		margin-bottom: 0.5rem;
	}

	h1 {
		font-size: 1.75rem;
		font-weight: 700;
		letter-spacing: -0.04em;
		margin-bottom: 0.5rem;
	}

	.description {
		color: var(--q-text-muted);
		line-height: 1.6;
	}

	#screen-start {
		text-align: center;
		padding: 3rem 0;
	}

	.meta {
		color: var(--q-text-subtle);
		margin-bottom: 1.5rem;
		font-size: 1.125rem;
	}

	.saved-notice {
		margin-bottom: 1rem;
	}

	.saved-text {
		font-size: 0.9375rem;
		color: var(--q-accent-light);
		margin-bottom: 1rem;
	}

	.start-btns {
		display: flex;
		gap: 0.75rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.progress-bar {
		height: 4px;
		background: var(--q-surface);
		border-radius: 2px;
		margin-bottom: 1rem;
		overflow: hidden;
	}

	#progress-fill {
		height: 100%;
		background: var(--q-accent-light);
		transition: width 0.3s ease;
		width: 0%;
	}

	.counter {
		color: var(--q-text-subtle);
		font-size: 0.875rem;
		margin-bottom: 1.5rem;
	}

	.question-text {
		font-size: 1.25rem;
		font-weight: 600;
		line-height: 1.5;
		margin-bottom: 1.5rem;
	}

	.options-list {
		display: flex;
		flex-direction: column;
		gap: 0.625rem;
		margin-bottom: 1.5rem;
	}

	.option-btn {
		width: 100%;
		display: flex;
		align-items: center;
		gap: 0.875rem;
		padding: 0.875rem 1rem;
		background: var(--q-bg);
		border: 1.5px solid var(--q-surface);
		border-radius: 0.75rem;
		color: var(--q-text-muted);
		font-size: 1rem;
		cursor: pointer;
		transition:
			border-color 0.15s,
			background 0.15s,
			color 0.15s,
			transform 0.1s,
			opacity 0.2s;
		text-align: left;
	}

	.option-letter {
		flex-shrink: 0;
		width: 2rem;
		height: 2rem;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 0.4rem;
		background: var(--q-surface);
		border: 1px solid var(--q-border);
		font-size: 0.75rem;
		font-weight: 700;
		color: var(--q-border-hover);
		transition:
			background 0.15s,
			border-color 0.15s,
			color 0.15s;
	}

	.option-text {
		flex: 1;
		line-height: 1.45;
	}

	.option-btn:hover:not(:disabled) {
		border-color: var(--q-accent);
		color: var(--q-text);
		transform: translateX(3px);
	}

	.option-btn:hover:not(:disabled) .option-letter {
		background: var(--q-accent-bg);
		border-color: var(--q-accent);
		color: var(--q-accent-light);
	}

	.option-btn.correct {
		border-color: var(--q-correct);
		background: var(--q-correct-bg);
		color: var(--q-correct-text);
	}

	.option-btn.correct .option-letter {
		background: var(--q-correct-bg);
		border-color: var(--q-correct);
		color: var(--q-correct);
	}

	.option-btn.wrong {
		border-color: var(--q-wrong);
		background: var(--q-wrong-bg);
		color: var(--q-wrong-text);
	}

	.option-btn.wrong .option-letter {
		background: var(--q-wrong-bg);
		border-color: var(--q-wrong);
		color: var(--q-wrong);
	}

	.option-btn:disabled {
		cursor: default;
	}

	.option-btn:disabled:not(.correct):not(.wrong) {
		opacity: 0.4;
	}

	.explanation {
		padding: 0.875rem 1rem;
		background: var(--q-accent-bg);
		border-left: 3px solid var(--q-accent-light);
		border-radius: 0 0.5rem 0.5rem 0;
		color: var(--q-accent-text);
		font-size: 0.9375rem;
		line-height: 1.6;
		margin-bottom: 1rem;
	}

	#screen-results {
		text-align: center;
		padding: 2rem 0;
	}

	.results-inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
	}

	.score-circle {
		width: 120px;
		height: 120px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 1.5rem;
		font-weight: 700;
		background: var(--q-surface);
		border: 4px solid var(--q-border);
	}

	.score-circle.excellent {
		border-color: var(--q-correct);
		color: var(--q-correct);
	}

	.score-circle.good {
		border-color: #f59e0b;
		color: #f59e0b;
	}

	.score-circle.poor {
		border-color: var(--q-wrong);
		color: var(--q-wrong);
	}

	#result-title {
		font-size: 1.5rem;
		font-weight: 700;
	}

	.result-detail {
		color: var(--q-text-subtle);
	}

	.result-actions {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
		justify-content: center;
		margin-top: 0.5rem;
	}

	.btn-primary {
		padding: 0.75rem 2rem;
		background: var(--q-accent);
		color: white;
		border: none;
		border-radius: 0.5rem;
		font-size: 1rem;
		font-weight: 600;
		cursor: pointer;
		transition: background 0.15s;
	}

	.btn-primary:hover {
		background: var(--q-accent-hover);
	}

	.btn-secondary {
		padding: 0.75rem 2rem;
		background: var(--q-surface);
		color: var(--q-text);
		border: 1px solid var(--q-border);
		border-radius: 0.5rem;
		font-size: 1rem;
		font-weight: 600;
		cursor: pointer;
	}

	.btn-secondary:hover {
		background: var(--q-border);
	}

	.btn-outline {
		display: inline-block;
		padding: 0.75rem 2rem;
		background: transparent;
		color: var(--q-accent-light);
		border: 1px solid var(--q-accent);
		border-radius: 0.5rem;
		font-size: 1rem;
		font-weight: 600;
		text-decoration: none;
	}

	.btn-outline:hover {
		background: var(--q-accent-bg);
	}

	.hidden {
		display: none !important;
	}
</style>
