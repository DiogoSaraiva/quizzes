---
interface Props {
	title?: string;
	description?: string;
}

const { title = "Quizzes", description = "Plataforma de quizzes interativos" } =
	Astro.props;
// Favicon: substitui public/favicon.svg e public/favicon.ico pelo logo do site pai.
---

<!doctype html>
<html lang="pt">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title} | Quizzes</title>
	</head>
	<body>
		<header>
			<nav>
				<a href="/" class="brand">Quizzes</a>
			</nav>
		</header>
		<main>
			<slot />
		</main>
	</body>
</html>

<style>
	*,
	*::before,
	*::after {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	body {
		font-family: system-ui, -apple-system, sans-serif;
		background: #0f172a;
		color: #e2e8f0;
		min-height: 100vh;
	}

	header {
		border-bottom: 1px solid #1e293b;
		padding: 1rem 2rem;
	}

	nav {
		max-width: 900px;
		margin: 0 auto;
	}

	.brand {
		font-size: 1.25rem;
		font-weight: 700;
		color: #60a5fa;
		text-decoration: none;
		letter-spacing: -0.025em;
	}

	main {
		max-width: 900px;
		margin: 0 auto;
		padding: 2rem;
	}
</style>
