---
import { BRAND } from "../generated/brand";

interface Props {
	title?: string;
	brand?: string;
}

const {
	title = "Quizzes",
	brand = BRAND,
} = Astro.props;

const showSuffix = brand !== "Quizzes";
const brandLabel = showSuffix ? `${brand} Quizzes` : "Quizzes";

const user = Astro.locals.user;
---

<!doctype html>
<html lang="pt">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<!-- theme.css opcional: copiado do pai por copy-assets.js, sobrescreve as variáveis abaixo -->
		<link rel="stylesheet" href="/theme.css" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | {brandLabel}</title>
	</head>
	<body>
		<header>
			<nav>
				<a href="/" class="brand">
					{brand}
					{showSuffix && <span class="brand-suffix">&nbsp;Quizzes</span>}
				</a>
				<div class="nav-right">
					<a href="/leaderboard" class="nav-link">Leaderboard</a>
					{user && (user.role === "editor" || user.role === "admin") && (
						<a href="/upload" class="nav-link">Carregar Quiz</a>
					)}
					{user && user.role === "admin" && (
						<a href="/admin" class="nav-link nav-admin">Admin</a>
					)}
					{user ? (
						<>
							<a href="/profile" class="nav-user">{user.username}</a>
							<a href="/api/auth/logout" class="nav-link">Sair</a>
						</>
					) : (
						<a href="/login" class="nav-link">Entrar</a>
					)}
				</div>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer>
			<a href="/privacy" class="footer-link">Política de Privacidade</a>
		</footer>
	</body>
</html>

<style is:global>
	/* ── Variáveis de tema ─────────────────────────────────────────────────────
	   O ficheiro public/theme.css (copiado do pai) pode sobrescrever estas vars.
	   ───────────────────────────────────────────────────────────────────────── */
	html {
		--q-bg:             #0f172a;
		--q-surface:        #1e293b;
		--q-surface-hover:  #1e3a5f;
		--q-border:         #334155;
		--q-border-hover:   #475569;
		--q-text:           #e2e8f0;
		--q-text-muted:     #94a3b8;
		--q-text-subtle:    #64748b;
		--q-accent:         #3b82f6;
		--q-accent-hover:   #2563eb;
		--q-accent-light:   #60a5fa;
		--q-accent-bg:      #1e3a5f;
		--q-accent-text:    #bfdbfe;
		--q-correct:        #22c55e;
		--q-correct-bg:     #052e16;
		--q-correct-text:   #bbf7d0;
		--q-wrong:          #ef4444;
		--q-wrong-bg:       #1c0404;
		--q-wrong-text:     #fecaca;
		--q-font:           system-ui, -apple-system, sans-serif;
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	body {
		font-family: var(--q-font);
		background: var(--q-bg);
		color: var(--q-text);
		min-height: 100vh;
	}

	header {
		border-bottom: 1px solid var(--q-border);
		padding: 1rem 2rem;
	}

	nav {
		max-width: 900px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		font-size: 1.25rem;
		font-weight: 700;
		color: var(--q-accent-light);
		text-decoration: none;
		letter-spacing: -0.025em;
	}

	.brand span {
		color: var(--q-accent);
	}

	.brand .brand-suffix {
		color: var(--q-accent-light);
	}

	.nav-right {
		display: flex;
		align-items: center;
		gap: 1.25rem;
	}

	.nav-link {
		font-size: 0.875rem;
		color: var(--q-text-muted);
		text-decoration: none;
		transition: color 0.15s;
	}

	.nav-link:hover {
		color: var(--q-text);
	}

	.nav-admin {
		color: var(--q-accent-light);
	}

	.nav-user {
		font-size: 0.875rem;
		color: var(--q-accent-light);
		font-weight: 600;
		text-decoration: none;
	}

	.nav-user:hover {
		color: var(--q-text);
	}

	main {
		max-width: 900px;
		margin: 0 auto;
		padding: 2rem;
	}

	footer {
		border-top: 1px solid var(--q-border);
		padding: 1.25rem 2rem;
		text-align: center;
	}

	.footer-link {
		font-size: 0.75rem;
		color: var(--q-border-hover);
		text-decoration: none;
		transition: color 0.15s;
	}

	.footer-link:hover {
		color: var(--q-text-subtle);
	}

	.hidden {
		display: none !important;
	}

	/* Botões globais reutilizados em várias páginas */
	.btn-primary {
		padding: 0.75rem 2rem;
		background: var(--q-accent);
		color: white;
		border: none;
		border-radius: 0.5rem;
		font-size: 1rem;
		font-weight: 600;
		cursor: pointer;
		transition: background 0.15s;
	}

	.btn-primary:hover {
		background: var(--q-accent-hover);
	}

	.btn-secondary {
		padding: 0.75rem 2rem;
		background: var(--q-surface);
		color: var(--q-text);
		border: 1px solid var(--q-border);
		border-radius: 0.5rem;
		font-size: 1rem;
		font-weight: 600;
		cursor: pointer;
		transition: background 0.15s, border-color 0.15s;
	}

	.btn-secondary:hover {
		background: var(--q-border);
	}

	.btn-outline {
		display: inline-block;
		padding: 0.75rem 2rem;
		background: transparent;
		color: var(--q-accent-light);
		border: 1px solid var(--q-accent);
		border-radius: 0.5rem;
		font-size: 1rem;
		font-weight: 600;
		text-decoration: none;
		transition: background 0.15s;
	}

	.btn-outline:hover {
		background: var(--q-accent-bg);
	}
</style>
