---
interface Props {
	title?: string;
	description?: string;
}

const { title = "Quizzes", description = "Plataforma de quizzes interativos" } =
	Astro.props;

const user = Astro.locals.user;
// Favicon: substitui public/favicon.svg e public/favicon.ico pelo logo do site pai.
---

<!doctype html>
<html lang="pt">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title} | Quizzes</title>
	</head>
	<body>
		<header>
			<nav>
				<a href="/" class="brand">Quizzes</a>
				<div class="nav-right">
					<a href="/leaderboard" class="nav-link">Leaderboard</a>
					{user ? (
						<>
							<span class="nav-user">{user.username}</span>
							<a href="/api/auth/logout" class="nav-link">Sair</a>
						</>
					) : (
						<a href="/login" class="nav-link">Entrar</a>
					)}
				</div>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer>
			<a href="/privacy" class="footer-link">Política de Privacidade</a>
		</footer>
	</body>
</html>

<style>
	*,
	*::before,
	*::after {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	body {
		font-family: system-ui, -apple-system, sans-serif;
		background: #0f172a;
		color: #e2e8f0;
		min-height: 100vh;
	}

	header {
		border-bottom: 1px solid #1e293b;
		padding: 1rem 2rem;
	}

	nav {
		max-width: 900px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.brand {
		font-size: 1.25rem;
		font-weight: 700;
		color: #60a5fa;
		text-decoration: none;
		letter-spacing: -0.025em;
	}

	.nav-right {
		display: flex;
		align-items: center;
		gap: 1.25rem;
	}

	.nav-link {
		font-size: 0.875rem;
		color: #94a3b8;
		text-decoration: none;
		transition: color 0.15s;
	}

	.nav-link:hover {
		color: #e2e8f0;
	}

	.nav-user {
		font-size: 0.875rem;
		color: #60a5fa;
		font-weight: 600;
	}

	main {
		max-width: 900px;
		margin: 0 auto;
		padding: 2rem;
	}

	footer {
		border-top: 1px solid #1e293b;
		padding: 1.25rem 2rem;
		text-align: center;
	}

	.footer-link {
		font-size: 0.75rem;
		color: #334155;
		text-decoration: none;
		transition: color 0.15s;
	}

	.footer-link:hover {
		color: #64748b;
	}
</style>
